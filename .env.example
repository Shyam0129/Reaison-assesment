PORT=3000
NODE_ENV=development

# PostgreSQL connection string (Points to local postgres if using docker-compose)
DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:5432/agent_locator?schema=public"

# Redis connection string (Points to local redis if using docker-compose)
REDIS_URL="redis://localhost:6379"

# Security
CORS_ORIGIN="http://localhost:3001"
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
